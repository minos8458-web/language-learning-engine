# LLE Production — 환경 변수 템플릿
# 실제 값은 .env 파일에 넣고 커밋하지 않는다(.gitignore에서 제외됨).

# PostgreSQL 연결 정보 (db/pool.js가 사용)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=devpassword
PGDATABASE=lle_dev

NODE_ENV=development

# 아래 값들은 이후 Phase(API Layer, Phase 5)에서 사용 예정 — Phase 0에서는 미사용
# LLE_JWT_SECRET=
